{
  "name": "hardware-erp",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "npm run dev --workspace=@hardware-erp/api",
    "dev:web": "npm run dev --workspace=@hardware-erp/web",
    "build": "npm run build --workspaces",
    "db:migrate": "npm run migrate --workspace=@hardware-erp/db",
    "db:seed": "npm run seed --workspace=@hardware-erp/db",
    "db:generate": "npm run generate --workspace=@hardware-erp/db",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.3.3"
  }
}
